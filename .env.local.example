# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL for parent payment links (e.g. https://yourcenter.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
# Snap checkout created when parents open /pay/{token}
MIDTRANS_PAGE_EXPIRY_HOURS=24
MIDTRANS_RETRY_ATTEMPTS=4
MIDTRANS_RETRY_BASE_DELAY_MS=2000
MIDTRANS_BACKFILL_BATCH_LIMIT=50

# WhatsApp (Meta Cloud API)
META_ACCESS_TOKEN=           # permanent token from Meta Business Manager
META_PHONE_NUMBER_ID=        # phone number ID from Meta dashboard
META_TEMPLATE_REMINDER_NAME=kumon_payment_reminder
META_TEMPLATE_REMINDER_LANGUAGE=id
META_TEMPLATE_CONFIRMATION_NAME=kumon_payment_confirmation
META_TEMPLATE_CONFIRMATION_LANGUAGE=id
# Set once templates are APPROVED in WhatsApp Manager for the same phone number as META_PHONE_NUMBER_ID.
# Name and language must match exactly (e.g. name=kumon_payment_reminder, language=id).
# If you get (#132001), the template is missing on this number/WABA or the language code is wrong.
# Reminder named vars: nama_orang_tua, nama_siswa, bulan_tagihan, total_tagihan, link_pembayaran, mata_pelajaran
# Confirmation named vars: nama_orang_tua, nama_siswa, bulan_tagihan, total_tagihan, mata_pelajaran
# META_TEMPLATE_REMINDER_NAME=kumon_payment_reminder
# META_TEMPLATE_REMINDER_LANGUAGE=id
# META_TEMPLATE_CONFIRMATION_NAME=kumon_payment_confirmation
# META_TEMPLATE_CONFIRMATION_LANGUAGE=id

# Rate limiting for cron sends (cron jobs tuned for 1000 students)
WHATSAPP_SEND_DELAY_MS=2000
WHATSAPP_BATCH_LIMIT=100

# Cron auth (CRON_SECRET required on Vercel for scheduled GET jobs)
WEBHOOK_SECRET=
CRON_SECRET=

# Admin failure alerts (Resend). Email sent when the billing watchdog finds missing
# invoices, or any cron / webhook handler fails for a genuine reason (5xx / unexpected
# throw — not benign 4xx control flow).
# All three must be set for alerts to send; if unset, alerts are silently skipped.
RESEND_API_KEY=              # Resend dashboard → API Keys
ALERT_EMAIL_FROM=            # verified sender, e.g. alerts@yourcenter.com
ALERT_EMAIL_TO=              # where alerts go, e.g. admin@yourcenter.com

# Meta WhatsApp delivery webhook (status callbacks: sent/delivered/read/failed)
META_APP_SECRET=             # Meta App → Settings → Basic → App Secret (verifies X-Hub-Signature-256)
META_VERIFY_TOKEN=           # any random string; must match the value set in the Meta webhook config
